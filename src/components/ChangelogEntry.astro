---
interface Props {
  date: string;
  note: string;
}

const { date, note } = Astro.props;
---

<div class="changelog-entry">
  <span class="changelog-dot"></span>
  <time class="changelog-date">{date}</time>
  <span class="changelog-note">{note}</span>
</div>

<style>
  .changelog-entry {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.35rem 0;
  }

  .changelog-dot {
    width: 6px;
    height: 6px;
    min-width: 6px;
    border-radius: 50%;
    background-color: var(--color-moss, #6B8F71);
    position: relative;
    top: 1px;
  }

  .changelog-date {
    font-family: var(--font-mono, "IBM Plex Mono", monospace);
    font-size: 0.8rem;
    color: var(--color-text-muted, #7A7A7A);
    white-space: nowrap;
  }

  .changelog-note {
    font-size: 0.9rem;
    color: var(--color-text, #2C2C2C);
  }
</style>
